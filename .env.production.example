# Copy this file outside version control and replace the empty secret value.
DJANGO_SECRET_KEY=
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# Enable these after HTTPS termination and redirect behavior are verified.
DJANGO_SESSION_COOKIE_SECURE=true
DJANGO_CSRF_COOKIE_SECURE=true
DJANGO_SECURE_SSL_REDIRECT=true

# During rollout, start HSTS with a short duration. The final values below make
# check --deploy pass and should be used only when every subdomain is HTTPS-only.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
DJANGO_SECURE_HSTS_PRELOAD=true

# Set true only when the trusted proxy overwrites X-Forwarded-Proto.
DJANGO_TRUST_X_FORWARDED_PROTO=false
